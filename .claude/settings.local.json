{
  "permissions": {
    "allow": [
      "Bash(just link:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(prek run:*)"
    ],
    "additionalDirectories": [
      "C:\\git\\adlc"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session started: tech-lead-orchestrator, best practices, and memory sync active'",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.dotfiles/tools/ai/hooks/tech-lead-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.dotfiles/tools/ai/hooks/tech-lead-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.dotfiles/tools/ai/hooks/enforce-best-practices.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.dotfiles/tools/ai/hooks/memory-sync.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.dotfiles/tools/ai/hooks/compound-engineering.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
