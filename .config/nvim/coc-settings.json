{
  "eslint.autoFixOnSave": true,
  "suggest.noselect": false,
  "eslint.filetypes": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "graphql"
  ],
  "tsserver.formatOnType": true,
  "coc.preferences.formatOnType": true,
  "clangd.enabled": true,
  "clangd.checkUpdates": true
}
