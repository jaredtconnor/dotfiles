#!/usr/bin/env bash
{{/*
    Flat-symlinks skills and agents from cloned external repos into
    ~/.claude and ~/.cursor. Runs after every `chezmoi apply` but only
    touches the filesystem when symlinks are missing or stale.
*/}}

set -euo pipefail

CLAUDE_SKILLS="$HOME/.claude/skills"
CLAUDE_AGENTS="$HOME/.claude/agents"
CURSOR_SKILLS="$HOME/.cursor/skills"
CURSOR_AGENTS="$HOME/.cursor/agents"

mkdir -p "$CLAUDE_SKILLS" "$CLAUDE_AGENTS" "$CURSOR_SKILLS" "$CURSOR_AGENTS"

CHANGED=0

ensure_link() {
    local target="$1" link_path="$2"
    if [[ -L "$link_path" ]] && [[ "$(readlink "$link_path")" == "$target" ]]; then
        return
    fi
    ln -sfn "$target" "$link_path"
    CHANGED=1
}

link_from() {
    local root="$1"
    [ -d "$root" ] || return 0

    if [ -d "$root/skills" ]; then
        for skill in "$root/skills"/*/; do
            [ -d "$skill" ] || continue
            local name
            name=$(basename "$skill")
            ensure_link "${skill%/}" "$CLAUDE_SKILLS/$name"
            ensure_link "${skill%/}" "$CURSOR_SKILLS/$name"
        done
    fi

    if [ -d "$root/agents" ]; then
        for agent in "$root/agents"/*/; do
            [ -d "$agent" ] || continue
            local name
            name=$(basename "$agent")
            ensure_link "${agent%/}" "$CLAUDE_AGENTS/$name"
            ensure_link "${agent%/}" "$CURSOR_AGENTS/$name"
        done
    fi
}

link_from "$HOME/.local/share/chezmoi-skills-personal"

{{ if .work -}}
link_from "$HOME/.local/share/chezmoi-skills-work"
{{- end }}

if [[ "$CHANGED" -gt 0 ]]; then
    echo "AI skills/agents mirror refreshed"
fi
