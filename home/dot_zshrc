# ~/.zshrc — chezmoi-managed, OS-detected at runtime (no template needed).
# All content directories moved to XDG paths under ~/.config/zsh/.

eval "$(starship init zsh)"

# zgenom framework
source ~/.zgenom/zgenom.zsh

# Homebrew setup — OS detection
if [[ "$OSTYPE" == "darwin"* ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if [[ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
fi

export GPG_TTY=$TTY
[[ -f "$HOME/.config/zsh/zoxide-env.zsh" ]] && source "$HOME/.config/zsh/zoxide-env.zsh"

# zgenom compdump name
export ZGEN_CUSTOM_COMPDUMP="~/.zcompdump-$(whoami).zwc"

if ! zgenom saved; then
    echo "-- zgenom: Regenerating plugins..."
    zgenom ohmyzsh

    zgenom ohmyzsh plugins/git
    zgenom ohmyzsh plugins/github
    zgenom ohmyzsh plugins/sudo
    zgenom ohmyzsh plugins/command-not-found
    zgenom ohmyzsh plugins/kubectl

    if command -v docker >/dev/null 2>&1; then
        zgenom ohmyzsh plugins/docker
        zgenom ohmyzsh plugins/docker-compose
    fi

    zgenom load jocelynmallon/zshmarks
    zgenom load denolfe/git-it-on.zsh
    zgenom load caarlos0/zsh-mkc
    zgenom load caarlos0/zsh-git-sync
    zgenom load caarlos0/zsh-add-upstream
    zgenom load denolfe/zsh-prepend
    zgenom ohmyzsh plugins/zoxide
    zgenom load reegnz/jq-zsh-plugin
    zgenom load ntnyq/omz-plugin-pnpm
    zgenom load zsh-users/zsh-autosuggestions
    zgenom load zsh-users/zsh-completions
    zgenom load zsh-users/zsh-syntax-highlighting
    zgenom load zsh-users/zsh-history-substring-search
    zgenom load djui/alias-tips
    zgenom load zsh-users/zsh-completions

    echo "-- zgenom: Saving configuration..."
    zgenom save
    echo "-- zgenom: Done!"
fi

# history-substring-search keybindings
zmodload zsh/terminfo
bindkey "$terminfo[kcuu1]" history-substring-search-up
bindkey "$terminfo[kcud1]" history-substring-search-down
bindkey "^k" history-substring-search-up
bindkey "^j" history-substring-search-down

# History options
setopt append_history extended_history hist_expire_dups_first hist_ignore_all_dups
setopt hist_ignore_dups hist_ignore_space hist_reduce_blanks hist_save_no_dups
setopt hist_verify inc_append_history sharehistory pushd_ignore_dups

HISTSIZE=1000000000
SAVEHIST=$HISTSIZE
HISTFILE=~/.zsh_history
HISDUP=erase
export HISTIGNORE="ls:cd:cd -:pwd:exit:date:* --help"

REPORTTIME=2
TIMEFMT="%U user %S system %P cpu %*Es total"

# Per-machine local overrides
test -f ~/.zshrc.local && source ~/.zshrc.local

# Secrets (rendered by chezmoi from private_dot_env.tmpl)
test -f ~/.env && source ~/.env

# Load functions (sourced — not symlinked to PATH)
if [[ -d "$HOME/.config/zsh/functions" ]]; then
    for f in "$HOME/.config/zsh/functions"/*.sh; do
        [[ -r "$f" ]] && source "$f"
    done
fi

# Load aliases
if [[ -d "$HOME/.config/zsh/aliases" ]]; then
    for f in "$HOME/.config/zsh/aliases"/*.aliases.sh; do
        [[ -r "$f" ]] && source "$f"
    done
fi

# Load path augmenters
if [[ -d "$HOME/.config/zsh/paths" ]]; then
    for f in "$HOME/.config/zsh/paths"/*.path.sh; do
        [[ -r "$f" ]] && source "$f"
    done
fi

# FZF
if type fd > /dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --type f'
fi
export FZF_DEFAULT_OPTS='--reverse --bind ctrl-l:cancel --height=90% --pointer=▶'
[[ -f "$HOME/.config/zsh/fzf-theme-dark-plus.sh" ]] && source "$HOME/.config/zsh/fzf-theme-dark-plus.sh"
export FZF_TMUX_HEIGHT=80%
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

export BAT_THEME='Visual Studio Dark+'
export AWS_PAGER='bat -p'

# Crystal on mac
if [[ "$OSTYPE" == "darwin"* ]]; then
    export PKG_CONFIG_PATH=$PKG_CONFIG_PATH:/usr/local/opt/openssl/lib/pkgconfig
fi

# pnpm
if [[ "$OSTYPE" == "darwin"* ]]; then
    export PNPM_HOME="$HOME/Library/pnpm"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    export PNPM_HOME="$HOME/.local/share/pnpm"
fi
case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
esac

[[ -f ~/.config/tabtab/zsh/__tabtab.zsh ]] && . ~/.config/tabtab/zsh/__tabtab.zsh || true

export ZSH="$HOME/.oh-my-zsh"

if [[ "$OSTYPE" == "darwin"* ]]; then
    export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH
    alias ibrew='arch -x86_64 /usr/local/bin/brew'
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if [[ -d "/home/linuxbrew/.linuxbrew/bin" ]]; then
        export PATH=/home/linuxbrew/.linuxbrew/bin:$PATH
    fi
fi

if type brew &>/dev/null; then
    FPATH=$(brew --prefix)/share/zsh/site-functions:$FPATH
    autoload -Uz compinit
    compinit
fi

eval "$(mise activate zsh)"

# 1Password completions
if command -v op >/dev/null 2>&1; then
    eval "$(op completion zsh)"; compdef _op op
fi

# Go
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin

# Deno
if [[ -n "$DENO_INSTALL" ]]; then
    export PATH="$DENO_INSTALL/bin:$PATH"
elif [[ -d "$HOME/.deno" ]]; then
    export DENO_INSTALL="$HOME/.deno"
    export PATH="$DENO_INSTALL/bin:$PATH"
fi

bindkey -s ^a "nvims\n"

# Bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Node
if [[ "$OSTYPE" == "darwin"* ]]; then
    export PATH="/opt/homebrew/opt/node/bin:$PATH"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if [[ -d "/home/linuxbrew/.linuxbrew/opt/node/bin" ]]; then
        export PATH="/home/linuxbrew/.linuxbrew/opt/node/bin:$PATH"
    fi
fi

# Color configuration
if [[ "$TERM_PROGRAM" != "ghostty" ]]; then
    export TERM="xterm-256color"
fi

if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    export COLORTERM=truecolor
    if [[ -n "$WSL_DISTRO_NAME" ]]; then
        export FORCE_COLOR=1
    fi
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
    alias diff='diff --color=auto'
    if command -v dircolors >/dev/null 2>&1; then
        eval "$(dircolors -b)"
    fi
fi

zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#)*=0=01;31'
zstyle ':completion:*:kill:*' command 'ps -u $USER -o pid,%cpu,tty,cputime,cmd'
